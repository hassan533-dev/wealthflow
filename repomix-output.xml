                      width: `${progress}%`,
                      backgroundColor: isOver ? "#f43f5e" : category.color,
                    }}
                  />
                </div>
              </button>
            );
          })}
        </div>
      </section>

      {/* History Section */}
      <HistorySection
        transactions={transactions}
        currency={settings.currency}
        hideBalance={settings.hideBalance}
        onDelete={onDeleteTransaction}
      />

      {/* Bottom spacer for mobile */}
      <div className="h-4" />
    </div>
  );
}
