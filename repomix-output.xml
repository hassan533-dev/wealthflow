import { useMemo, useState } from "react";

type CreateCategorySheetProps = {
  open: boolean;
  onClose: () => void;
  onCreate: (input: { name: string; color: string; icon: string; limit: number }) => Promise<void>;
  currency: string;
};

const colorPalette = [
