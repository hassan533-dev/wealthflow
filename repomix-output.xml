              {/* Summary */}
              <div className="rounded-2xl border border-[var(--wf-emerald)]/20 bg-[var(--wf-emerald)]/5 p-4">
                <p className="mb-2 text-[10px] font-bold uppercase tracking-widest text-[var(--wf-emerald)]">
